create table david_customers (
    customer_id NUMBER PRIMARY KEY,
    first_name VARCHAR2(100),
    last_name VARCHAR2(100),
    email VARCHAR2(100) not null unique,
    created_at DATE default SYSDATE NOT NULL
);

create table david_products (
    product_id NUMBER PRIMARY KEY,
    name VARCHAR2(100),
    price NUMBER(10,2),
    stock_quantity number default 0
        constraint check_stock
        check (stock_quantity >= 0),
    active VARCHAR2(1) 
        CONSTRAINT chk_product_active
        CHECK (active in ('Y', 'N'))
 );
  
 create table david_order (
    order_id NUMBER PRIMARY KEY,
    customer_id number,
    FOREIGN KEY (customer_id) REFERENCES david_customers(customer_id),
    order_date DATE,
    status VARCHAR(20) 
        CONSTRAINT chk_order_status 
        CHECK(status IN ('CANCELLED', 'CREATED', 'COMPLETED')),
    total_amount NUMBER(10,2) DEFAULT 0 NOT NULL
 );


alter table david_order ADD (
    created_by VARCHAR(20) DEFAULT SYS_CONTEXT('USERENV', 'SESSION_USER'),
    created_at DATE DEFAULT SYSDATE NOT NULL,
    modified_by VARCHAR(20) DEFAULT SYS_CONTEXT('USERENV', 'SESSION_USER'),
    modified_at DATE DEFAULT SYSDATE NOT NULL
);

create sequence order_seq
MINVALUE 21
INCREMENT BY 1
CACHE 20;

create SEQUENCE order_id_seq
    MINVALUE 20
    START WITH 20
    INCREMENT BY 1
    CACHE 20;



CREATE OR REPLACE TRIGGER trg_david_orders
BEFORE UPDATE ON david_order
FOR EACH ROW
BEGIN 
    IF UPDATING THEN
        :NEW.modified_by := NVL(SYS_CONTEXT('USERENV', 'CLIENT_IDENTIFIER'), USER);
        :NEW.modified_at := SYSDATE;
    END IF;
END;  
/
  
