from david_customers c
join david_order o on c.customer_id = o.customer_id;

--Ispis svih proizvoda i koliko puta su naručeni (LEFT JOIN + GROUP BY)
select 
    p.product_id,
    p.name,
    count(oi.order_item_id) as times_ordered
from david_products p
left join david_order_items oi 
    on p.product_id = oi.product_id
group by 
    p.product_id,
    p.name
order by times_ordered desc;

